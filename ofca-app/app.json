{
  "expo": {
    "name": "OFCA",
    "slug": "ofca-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ofca.app"
    },
    "android": {
      "package": "com.ofca.app",
      "versionCode": 1,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "buildToolsVersion": "34.0.0",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-file-system",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Nécessaire pour cartographier les parcelles GPS."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Nécessaire pour les photos de parcelles.",
          "cameraPermission": "Nécessaire pour photographier les parcelles."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f6181128-530e-40d5-a0c5-8b87b8d8a9b0"
      }
    },
    "owner": "mawussia"
  }
}